{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "none",
  "bracketSpacing": true,
  "arrowParens": "always",
  "bracketSameLine": true,
  "experimentalSortPackageJson": true,
  "ignorePatterns": [".output", ".wxt", "public", "changelog.md"]
}
